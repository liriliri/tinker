{
  "name": "tinker-timer",
  "version": "0.1.0",
  "description": "Timer Plugin for TINKER",
  "scripts": {
    "dev": "vite --config ../vite.config.ts",
    "build": "vite build --config ../vite.config.ts"
  },
  "tinker": {
    "name": "Timer",
    "description": "Stopwatch and countdown timer with flip clock display",
    "icon": "icon.png",
    "main": "dist/index.html",
    "locales": {
      "zh-CN": {
        "name": "计时器",
        "description": "秒表和倒计时，翻页时钟风格显示"
      }
    }
  },
  "devDependencies": {
    "flipclock": "^1.0.1"
  }
}
