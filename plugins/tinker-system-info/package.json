{
  "name": "tinker-system-info",
  "version": "0.1.0",
  "description": "System Information Plugin for TINKER",
  "scripts": {
    "dev": "concurrently \"npm run dev:renderer\" \"npm run dev:preload\"",
    "dev:renderer": "vite build --watch --config ../vite.config.ts",
    "dev:preload": "vite build --watch --config ../vite.preload.ts",
    "build": "concurrently \"npm run build:renderer\" \"npm run build:preload\"",
    "build:renderer": "vite build --config ../vite.config.ts",
    "build:preload": "vite build --config ../vite.preload.ts"
  },
  "tinker": {
    "name": "System Info",
    "description": "System information viewer for hardware and software details",
    "main": "dist/renderer/index.html",
    "icon": "icon.png",
    "preload": "dist/preload/index.js",
    "locales": {
      "zh-CN": {
        "name": "系统信息",
        "description": "系统信息查看，显示硬件和软件详情"
      }
    },
    "mcp": {
      "tools": {
        "get": {
          "description": "Get system hardware and software information, including system, CPU, memory, graphics, OS, disk, audio, and network details.",
          "inputSchema": {
            "type": "object",
            "properties": {
              "section": {
                "type": "string",
                "enum": [
                  "system",
                  "cpu",
                  "mem",
                  "graphics",
                  "os",
                  "disk",
                  "audio",
                  "network"
                ],
                "description": "Optional section to return. Omit to return all sections."
              },
              "refresh": {
                "type": "boolean",
                "description": "If true, re-fetch fresh data before returning. Defaults to false (use cached data when available)."
              }
            }
          }
        }
      }
    }
  }
}
