{
  "name": "tinker-clock",
  "version": "0.1.0",
  "description": "Clock Plugin for TINKER",
  "scripts": {
    "dev": "vite --config ../vite.config.ts",
    "build": "vite build --config ../vite.config.ts"
  },
  "tinker": {
    "name": "Clock",
    "description": "Clock with flip, analog, and digital styles and timezone support",
    "icon": "icon.png",
    "main": "dist/index.html",
    "locales": {
      "zh-CN": {
        "name": "时钟",
        "description": "时钟，支持翻页、模拟和数字三种风格及时区切换"
      }
    }
  },
  "devDependencies": {
    "flipclock": "^1.0.1"
  }
}
