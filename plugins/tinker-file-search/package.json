{
  "name": "tinker-file-search",
  "version": "0.1.0",
  "description": "File Search Plugin for TINKER",
  "scripts": {
    "dev": "concurrently \"npm run dev:renderer\" \"npm run dev:preload\"",
    "dev:renderer": "vite build --watch --config ../vite.config.ts",
    "dev:preload": "vite build --watch --config ../vite.preload.ts",
    "build": "concurrently \"npm run build:renderer\" \"npm run build:preload\"",
    "build:renderer": "vite build --config ../vite.config.ts",
    "build:preload": "vite build --config ../vite.preload.ts"
  },
  "tinker": {
    "name": "File Search",
    "description": "Quick local file search",
    "main": "dist/renderer/index.html",
    "preload": "dist/preload/index.js",
    "icon": "icon.png",
    "locales": {
      "zh-CN": {
        "name": "文件搜索",
        "description": "快速本地文件搜索"
      }
    },
    "mcp": {
      "tools": {
        "search": {
          "description": "Search local files by name (Spotlight on macOS, Everything on Windows). Updates the plugin UI and returns up to 100 matching paths with size and dateModified. hasMore is true when more results may exist.",
          "inputSchema": {
            "type": "object",
            "properties": {
              "query": {
                "type": "string",
                "minLength": 1,
                "description": "File name search query. Supports patterns like *.pdf."
              }
            },
            "required": [
              "query"
            ]
          }
        }
      }
    }
  }
}
