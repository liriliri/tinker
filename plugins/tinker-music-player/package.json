{
  "name": "tinker-music-player",
  "version": "0.1.0",
  "description": "Local music player for TINKER",
  "scripts": {
    "dev": "concurrently \"npm run dev:renderer\" \"npm run dev:preload\"",
    "dev:renderer": "vite build --watch --config ../vite.config.ts",
    "dev:preload": "vite build --watch --config ../vite.preload.ts",
    "build": "concurrently \"npm run build:renderer\" \"npm run build:preload\"",
    "build:renderer": "vite build --config ../vite.config.ts",
    "build:preload": "vite build --config ../vite.preload.ts"
  },
  "tinker": {
    "name": "Music Player",
    "description": "Play local music files with playlist management",
    "main": "dist/renderer/index.html",
    "preload": "dist/preload/index.js",
    "icon": "icon.png",
    "locales": {
      "zh-CN": {
        "name": "音乐播放",
        "description": "播放本地音乐文件，支持播放列表管理"
      }
    }
  }
}
