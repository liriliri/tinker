{
  "name": "tinker-calendar",
  "version": "0.1.0",
  "description": "Calendar Plugin for TINKER",
  "scripts": {
    "dev": "vite --config ../vite.config.ts",
    "build": "vite build --config ../vite.config.ts"
  },
  "tinker": {
    "name": "Calendar",
    "description": "Calendar with event management, multiple views, and lunar calendar",
    "icon": "icon.png",
    "main": "dist/index.html",
    "locales": {
      "zh-CN": {
        "name": "日历",
        "description": "日历，支持事件管理、多种视图和农历显示"
      }
    }
  },
  "devDependencies": {
    "@fullcalendar/core": "^6.1.20",
    "@fullcalendar/daygrid": "^6.1.20",
    "@fullcalendar/interaction": "^6.1.20",
    "@fullcalendar/react": "^6.1.20",
    "@fullcalendar/timegrid": "^6.1.20",
    "js-calendar-converter": "^0.0.7"
  }
}
